{
  "expo": {
    "name": "SMC Scanner",
    "slug": "smc-scanner",
    "version": "1.0.0",
    "scheme": "smcscanner",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "ios": {
      "bundleIdentifier": "com.smcscanner_k7p2.runable",
      "supportsTablet": true
    },
    "android": {
      "package": "com.smcscanner_k7p2.runable",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": ["expo-router"],
    "extra": {
      "apiUrl": "http://localhost:3000"
    }
  }
}
